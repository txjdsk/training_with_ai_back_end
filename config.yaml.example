app:
  port: 8080
tls:
  cert_file: "your_cert_file"
  key_file: "your_key_file"
db:
redis:
  addr: "localhost:6379"
log:
  level: "debug"
  path: "./logs/app.log"
  max_size: 100
  max_backups: 3
  max_age: 30
  compress: true
  request_log_detail: true
llm:
  base_url: "https://api.siliconflow.cn/"
  model: "deepseek-chat"
  rewrite_model: "deepseek-chat"
  critique_model: "deepseek-chat"
  customer_model: "deepseek-chat"
  embedding_model: "your_embedding_model"
  temperature: 0.2
  max_tokens: 800
  rewrite_max_tokens: 300
  critique_max_tokens: 700
  timeout_seconds: 30
chroma:
  base_url: "your_local_chroma"
  collection: "training_with_ai_kb"
  top_k: 3
  timeout_seconds: 10
jwt:
  expire_hours: 72