# ----------------------------------------------------------------------
# 1. 编译产物与二进制文件
# ----------------------------------------------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib

# 构建输出目录
/bin/
/dist/
/build/
/out/

# ----------------------------------------------------------------------
# 2. 测试与代码覆盖率
# ----------------------------------------------------------------------
# `go test -c` 生成的测试二进制文件
*.test

# 代码覆盖率报告
*.out
*.prof
coverage.txt
coverage.html

# ----------------------------------------------------------------------
# 3. 依赖管理与工作区
# ----------------------------------------------------------------------

go.work
go.work.sum

# ----------------------------------------------------------------------
# 4. 环境变量与密钥
# ----------------------------------------------------------------------
# 数据库密码、API Key 的环境配置文件
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# 证书文件
*.pem
*.key
*.crt

# ----------------------------------------------------------------------
# 5. IDE 与 编辑器配置
# ----------------------------------------------------------------------
# GoLand
.idea/
*.iml

# VS Code
.vscode/

# 通用编辑器临时文件
*.swp
*~
.DS_Store

# ----------------------------------------------------------------------
# 6. 配置文件
# ----------------------------------------------------------------------
# 应用配置文件
config.yaml
config.json

# ----------------------------------------------------------------------
# 7. 其他文件
# ----------------------------------------------------------------------
# 日志文件
*.log
logs/
tmp/
# 其他临时文件
dump.rdb
*.tmp